-- === FUNÇÃO DE INSPEÇÃO === --
função local inspect(alvo)
    listPage.Visible = false
    detailPage.Visible = true
    título.Texto = "INVERTENDO: " .. target.Name:upper()

    para _, v em pares(gridScroll:GetChildren()) faça
        se v:IsA("TextButton") então v:Destroy() fim
    fim

    caractere local = alvo.Caractere
    se char então
        local hum = char:FindFirstChildOfClass("Humanoid")
        se zumbir então
            local s, d = pcall(function() return hum:GetAppliedDescription() end)
            se s e d então
                criarCartão(d.Camisa, "Camisa")
                criarCartão(d.Calças, "Calça")
                criarCartão(d.Face, "Rosto")
                partes do corpo local = {
                    {d.Cabeça, "Cabeça"}, {d.Torso, "Torso"},
                    {d.LeftArm, "Braço E."}, {d.RightArm, "Braço D."},
                    {d.LeftLeg, "Perna E."}, {d.RightLeg, "Perna D."}
                }
                para _, b em ipairs(bodyParts) faça createCard(b[1], b[2], true) fim
                para _, a em ipairs(d:GetAccessories(true)) faça createCard(a.AssetId, "Acessório") fim
            fim
        fim
    fim
fim

