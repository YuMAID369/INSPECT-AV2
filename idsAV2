        se b == LP então retorne falso fim
        retornar a.Nome:minúsculo() < b.Nome:minúsculo()
    fim)
    para _, p em pares(todosOsJogadores) faça
        local b = Instance.new("TextButton", listPage)
        b.Size = UDim2.new(1, -8, 0, 35)
