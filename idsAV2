-- === ATUALIZAÇÃO DA LISTA DE JOGADORES === --
local function updateList()
    for _, v in pairs(listPage:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    local allPlayers = Players:GetPlayers()
    table.sort(allPlayers, function(a, b) 
        if a == LP then return true end
        if b == LP then return false end
        return a.Name:lower() < b.Name:lower() 
    end)
    for _, p in pairs(allPlayers) do
        local b = Instance.new("TextButton", listPage)
        b.Size = UDim2.new(1, -8, 0, 35)
        b.BackgroundColor3 = (p == LP) and Color3.fromRGB(30, 60, 30) or Color3.fromRGB(22, 23, 27)
        local displayName = (p == LP) and " [VOCÊ] " .. p.DisplayName or "  " .. p.DisplayName
        b.Text = displayName .. " (@" .. p.Name .. ")"
        b.TextColor3 = (p == LP) and Color3.fromRGB(0, 255, 150) or Color3.new(1, 1, 1)
        b.TextXAlignment = Enum.TextXAlignment.Left
        b.Font = (p == LP) and Enum.Font.GothamBold or Enum.Font.Gotham
        b.ZIndex = 105
        Instance.new("UICorner", b)
        b.MouseButton1Click:Connect(function() inspect(p) end)
    end
end

