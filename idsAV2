-- === LÓGICA DE CARDS === --

local function createCard(id, defName, isBody)
    if not id or id == 0 or id == "" then return end

    local card = Instance.new("TextButton", gridScroll)
    card.BackgroundColor3 = Color3.fromRGB(22, 23, 27)
    card.Text = ""
    card.ZIndex = 104
    Instance.new("UICorner", card)

    local img = Instance.new("ImageLabel", card)
    img.Size = UDim2.new(1, -10, 0, 65)
    img.Position = UDim2.new(0, 5, 0, 5)
    img.BackgroundTransparency = 1
    img.Image = "rbxthumb://type=Asset&id=" .. id .. "&w=150&h=150"
    img.ZIndex = 105

    local t = Instance.new("TextLabel", card)
    t.Size = UDim2.new(1, -6, 0, 35)
    t.Position = UDim2.new(0, 3, 1, -45)
    t.Text = "..."
    t.TextColor3 = Color3.fromRGB(200, 200, 200)
    t.TextSize = 7
    t.TextWrapped = true
    t.BackgroundTransparency = 1
    t.ZIndex = 105

    task.spawn(function()
        local s, info = pcall(function() return Marketplace:GetProductInfo(id) end)
        t.Text = (s and info) and info.Name or defName
    end)

    card.MouseButton1Click:Connect(function()
        currentId = id
        currentType = defName
        isBodyPart = isBody or false
        cMsg.Text = "Copiar ID de: " .. (isBody and "CORPO" or "ITEM")
        confirmGui.Visible = true
    end)
end

-- === FUNÇÃO DE CONFIRMAR - CÓPIA PARA CLIPE === --
confirmBtn.MouseButton1Click:Connect(function()
    if not currentId then return end
    local success = pcall(function()
        if setclipboard then setclipboard(tostring(currentId)) end
    end)
    if success then
        confirmBtn.Text = "COPIADO!"
        task.wait(1)
        confirmBtn.Text = "COPIAR ID"
    end
    confirmGui.Visible = false
end)

cancelBtn.MouseButton1Click:Connect(function()
    confirmGui.Visible = false
end)

-- === FUNÇÃO DE INSPEÇÃO === --
local function inspect(target)
    listPage.Visible = false
    detailPage.Visible = true
    title.Text = "REVERSING: " .. target.Name:upper()

    for _, v in pairs(gridScroll:GetChildren()) do 
        if v:IsA("TextButton") then v:Destroy() end 
    end

    local char = target.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            local s, d = pcall(function() return hum:GetAppliedDescription() end)
            if s and d then
                createCard(d.Shirt, "Camisa")
                createCard(d.Pants, "Calça")
                createCard(d.Face, "Rosto")
                local bodyParts = {
                    {d.Head, "Cabeça"}, {d.Torso, "Torso"}, 
                    {d.LeftArm, "Braço E."}, {d.RightArm, "Braço D."}, 
                    {d.LeftLeg, "Perna E."}, {d.RightLeg, "Perna D."}
                }
                for _, b in ipairs(bodyParts) do createCard(b[1], b[2], true) end
                for _, a in ipairs(d:GetAccessories(true)) do createCard(a.AssetId, "Acessório") end
            end
        end
    end
end

